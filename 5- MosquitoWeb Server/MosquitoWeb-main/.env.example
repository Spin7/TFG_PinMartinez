# Copy this file to .env and fill in your credentials.
# NEVER commit the actual .env file — it is gitignored.

# PostgreSQL connection string (Neon or any Postgres provider)
DATABASE_URL=

# Supabase project URL and service-role key
SUPABASE_URL=
SUPABASE_KEY=

# Optional: ngrok auth token (only needed for local tunnelling during development)
NGROK_TOKEN=
